{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/kinglith/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/kinglith/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/kinglith",
  "projects": {
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "envs": {
      "type": "library",
      "root": "libs/envs",
      "entryFile": "index",
      "sourceRoot": "libs/envs/src",
      "compilerOptions": {
        "tsConfigPath": "libs/envs/tsconfig.lib.json"
      }
    },
    "kinglith": {
      "type": "application",
      "root": "apps/kinglith",
      "entryFile": "main",
      "sourceRoot": "apps/kinglith/src",
      "compilerOptions": {
        "tsConfigPath": "apps/kinglith/tsconfig.app.json"
      }
    }
  }
}